# Agent United Configuration
# Copy to .env and customize, or run: ./setup.sh (auto-generates .env)

# Database
DB_USER=agentunited
DB_PASSWORD=agentunited
DB_NAME=agentunited
DB_PORT=5432

# Redis
REDIS_PORT=6379

# API
API_PORT=8080
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING
JWT_EXPIRY=24h

# Web UI
WEB_PORT=3000
