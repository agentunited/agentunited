FROM golang:1.26-alpine AS builder
RUN apk add --no-cache git
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags="-w -s" -o /build/relay-client ./cmd/relay-client

FROM alpine:3.21
RUN apk add --no-cache ca-certificates tzdata
RUN addgroup -g 1000 app && adduser -D -u 1000 -G app app
WORKDIR /app
COPY --from=builder /build/relay-client /app/relay-client
USER app
CMD ["/app/relay-client"]
